table LoadDetails
	lineageTag: 64a71bfb-db8e-4311-9f08-b2407d81e9ac

	measure LoadMiles = sum(LoadDetails[load_miles_total])
		lineageTag: c4ca79d5-9e0e-422f-be26-11605cf73b6f

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Loadscount =
			
			DISTINCTCOUNT ( 'LoadDetails'[load_load_number] )
		formatString: 0
		lineageTag: 44761c45-d69b-4395-a186-bb16ae8a3482

	measure GrossWageAmount = sum(EarningsHistory[earnings_history_gross_amount])
		formatString: \$#,0;(\$#,0);\$#,0
		lineageTag: 52a87027-bac7-4229-b967-6f29351b39fa

	measure WageRatePerRevenueMile = [GrossWageAmount]/[LoadMiles]
		lineageTag: 31c5b328-e761-4af8-8017-bb605e873116

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure TotalAlerts = DISTINCTCOUNT ( DriverAlerts[alert_id])
		formatString: 0
		lineageTag: fa24c4c3-cf52-46cd-834b-b28758e0a727

