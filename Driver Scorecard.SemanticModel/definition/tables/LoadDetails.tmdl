	partition LoadDetails = m
		mode: import
		source =
				let
				    Source =
				        Sql.Database(
				            "lofzv5bdxbxepf3ufbs6kug4du-dpb5fjqdbnqezisyyjteyvx6hu.datawarehouse.fabric.microsoft.com",
				            "data_central_wh",
				            [
				                Query = "
				SELECT *
				FROM [data_central_wh].[gold].[vw_ibmi_load_combined]
				WHERE load_dispatch_date >= DATEADD(MONTH, -6, CAST(GETDATE() AS DATE))
				"
				            ]
				        ),
				
				    // Key
				    AddLoadDetailsKey = Table.AddColumn(
				        Source,
				        "LoadDetailsKey",
				        each Text.From([load_load_number]) & "-" & Text.From([load_dispatch]),
				        type text
				    ),
				
				    // Will we split? (2 when both seats populated, else 1)
				    AddSplitFactor = Table.AddColumn(
				        AddLoadDetailsKey,
				        "SplitFactor",
				        each
				            let
				                s1 =
				                    try Text.Trim(Text.From([load_seat_1_driver_code])) otherwise "",
				                s2 =
				                    try Text.Trim(Text.From([load_seat_2_driver_code])) otherwise ""
				            in
				                if (s1 <> "" and s2 <> "") then 2 else 1,
				        Int64.Type
				    ),
				
				    // Build list of drivers present (1 or 2)
				    AddDriverList = Table.AddColumn(
				        AddSplitFactor,
				        "DriverList",
				        each List.RemoveNulls(
				            {
				                let s = try Text.Trim(Text.From([load_seat_1_driver_code])) otherwise "" in if s = "" then null else s,
				                let s = try Text.Trim(Text.From([load_seat_2_driver_code])) otherwise "" in if s = "" then null else s
				            }
				        ),
				        type list
				    ),
				
				    // Keep only rows where at least one driver exists
				    KeepRowsWithDrivers = Table.SelectRows(AddDriverList, each List.Count([DriverList]) > 0),
				
				    // Duplicate rows per driver
				    ExpandDrivers = Table.ExpandListColumn(KeepRowsWithDrivers, "DriverList"),
				    RenameDriverCol = Table.RenameColumns(ExpandDrivers, {{"DriverList", "driver_code"}}),
				    ChangeDriverType = Table.TransformColumnTypes(RenameDriverCol, {{"driver_code", type text}}),
				
				    // Adjust miles by SplitFactor (always divide; 1 leaves unchanged, 2 splits 50/50)
				    AddAdjDeadHead = Table.AddColumn(
				        ChangeDriverType,
				        "load_miles_dead_head_adj",
				        each try Number.From([load_miles_dead_head]) / Number.From([SplitFactor]) otherwise null,
				        type number
				    ),
				    AddAdjTotal = Table.AddColumn(
				        AddAdjDeadHead,
				        "load_miles_total_adj",
				        each try Number.From([load_miles_total]) / Number.From([SplitFactor]) otherwise null,
				        type number
				    ),
				    AddAdjLoaded = Table.AddColumn(
				        AddAdjTotal,
				        "load_miles_loaded_adj",
				        each try Number.From([load_miles_loaded]) / Number.From([SplitFactor]) otherwise null,
				        type number
				    ),
				
				    // Drop old miles, rename adjusted to original names
				    RemoveOldMiles = Table.RemoveColumns(
				        AddAdjLoaded,
				        {"load_miles_dead_head", "load_miles_total", "load_miles_loaded"}
				    ),
				    RenameAdjMiles = Table.RenameColumns(
				        RemoveOldMiles,
				        {
				            {"load_miles_dead_head_adj", "load_miles_dead_head"},
				            {"load_miles_total_adj", "load_miles_total"},
				            {"load_miles_loaded_adj", "load_miles_loaded"}
				        }
				    ),
				
				    // Clean up: remove original seat columns + SplitFactor
				    Final =
				        Table.RemoveColumns(
				            RenameAdjMiles,
				            {"load_seat_1_driver_code", "load_seat_2_driver_code", "SplitFactor"}
				        )
				in
				    Final

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

