	measure 'SM Past Period Reference Label' = ```
			
			
			
			var _Current = [SM Date Param]
			var _LY = [SM Date Param Past Period]
			var _Growth = DIVIDE(_Current - _LY, _LY)
			VAR NumOfDigits =
			    IFERROR(
			            LEN( 
			                CONVERT( 
			                        INT( 
			                           [SM Date Param])
			                        , STRING ))
			            ,0)
			VAR Suffix =
			    ".0" &
			    SWITCH(
			        TRUE( ),
			        NumOfDigits >= 13,  "T",
			        NumOfDigits >= 10,  "B",
			        NumOfDigits >= 7,   "M",
			        NumOfDigits >= 4,   "K"
			    )
			VAR Commas =
			    REPT(",",
			        SWITCH(
			            TRUE( ),
			            NumOfDigits >= 13,  "4",
			            NumOfDigits >= 10,  "3",
			            NumOfDigits >= 7,   "2",
			            NumOfDigits >= 4,   "1"
			        )
			    )
			var _Format =     "#,##0" & Commas & Suffix & ";-#,##0" & Commas &Suffix 
			return
			IF (_Growth <> 0, 
			    
			"" &FORMAT(_Current-_LY, _Format)
			    &  
			        FORMAT(_Growth," | 0.0% ▲; | 0.0% ▼;")& ""," ")
			```
		displayFolder: Visual Measures\SVG
		lineageTag: 3ee26436-a02c-44a5-96ef-02edb24fb167

	measure 'SM Past Period subtitle' = ```
			
			var _LY = [SM Date Param Past Period]
			VAR NumOfDigits =
			    IFERROR(
			            LEN( 
			                CONVERT( 
			                        INT( 
			                           _LY)
			                        , STRING ))
			            ,0)
			VAR Suffix =
			    ".00" &
			    SWITCH(
			        TRUE( ),
			        NumOfDigits >= 13,  "T",
			        NumOfDigits >= 10,  "B",
			        NumOfDigits >= 7,   "M",
			        NumOfDigits >= 4,   "K"
			    )
			VAR Commas =
			    REPT(",",
			        SWITCH(
			            TRUE( ),
			            NumOfDigits >= 13,  "4",
			            NumOfDigits >= 10,  "3",
			            NumOfDigits >= 7,   "2",
			            NumOfDigits >= 4,   "1"
			        )
			    )
			var _Format =     "#,##0" & Commas & Suffix & ";-#,##0" & Commas &Suffix 
			var _Time = 
			    SWITCH([Selected Dates],
			    "1W", "Previous Week: ",
			    "1M","Previous Month: ",
			    "3M","Previous 3 Months: ",
			    "YTD","Previous Year Period: ",
			    "1Y","Previous Year: ")
			return
			_Time  &FORMAT(_LY, _Format)
			```
		displayFolder: Visual Measures\SVG
		lineageTag: dfaf2dc1-26df-4789-877b-0f8470821b33

