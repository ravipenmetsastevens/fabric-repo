	measure 'Last Month Value' =
			
			VAR Vals =
			    CALCULATETABLE(
			        ADDCOLUMNS(
			            SUMMARIZE('Datetime', 'Datetime'[MonthNum], 'Datetime'[Month Letter]),
			            "@Measure", [Selected Measure]
			        ),
			        ALLSELECTED()
			    )
			
			VAR LastValue =
			    CALCULATE(
			        [Selected Measure],
			        LASTNONBLANK(Vals, [Selected Measure])
			    )
			
			VAR CurrentValue = [Selected Measure]
			VAR CurrentMonth = SELECTEDVALUE('Datetime'[MonthNum])
			
			RETURN
			    IF(CurrentValue = LastValue, CurrentValue, BLANK())
