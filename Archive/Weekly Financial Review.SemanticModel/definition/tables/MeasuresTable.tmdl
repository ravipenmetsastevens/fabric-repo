	measure 'Selected Min Date' =
			
			Var MaxDate = [MaxDate] +1
			VAR MinDate = [MinDate] -1
			RETURN
			
			SWITCH([Selected Dates],
			    "1W",MaxDate -7,
			    "1M",EDATE(MaxDate, -1),
			    "3M",EDATE(MaxDate, -3),
			    "YTD",DATE(YEAR(MaxDate), 1, 1),
			    "1Y",EDATE(MaxDate, -12),
			    "ALL",MinDate )
		formatString: General Date
		displayFolder: Visual Measures\SVG
		lineageTag: 1dd397cc-5470-4557-80ab-434258bcd02b

	measure 'Selected Min Date Past Period' =
			
