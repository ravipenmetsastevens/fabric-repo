shared #"silver ibmi_unit" = let
  Source = Fabric.Warehouse(null),
  Navigation = Source{[workspaceId = "a6d2c31b-0b03-4c60-a258-c2664c56fe3d"]}[Data],
  #"Navigation 1" = Navigation{[warehouseId = "f8578495-391e-4e7e-b791-4949397ba86f"]}[Data],
  #"Navigation 2" = #"Navigation 1"{[Schema = "silver", Item = "ibmi_unit"]}[Data],

  // Filter per your SQL WHERE clause
  #"Filtered Rows" =
    Table.SelectRows(
      #"Navigation 2",
      each
        [unit_seat_1_driver_code] = "" and
        [is_truck_deleted] = "FALSE" and
        List.Contains({"ST","CD","AL"}, [unit_fleet_code]) and
        not List.Contains({"34","84","85"}, [unit_truck_division_code])
    ),

  // Add snapshot timestamp (UTC is safest for consistency)
  #"Added SnapshotTs" =
    Table.AddColumn(#"Filtered Rows", "snapshotTsUtc", each DateTimeZone.UtcNow(), type datetimezone),

  // Optional: also add a date column for easy partitioning/filtering in reports
  #"Added SnapshotDate" =
    Table.AddColumn(#"Added SnapshotTs", "snapshotDateUtc", each Date.From(DateTimeZone.UtcNow()), type date)

in
  #"Added SnapshotDate";
