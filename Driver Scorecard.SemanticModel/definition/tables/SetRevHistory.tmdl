	partition SetRevHistory = m
		mode: import
		source =
				let
				    Source = Sql.Database("lofzv5bdxbxepf3ufbs6kug4du-dpb5fjqdbnqezisyyjteyvx6hu.datawarehouse.fabric.microsoft.com", "data_central_wh", [Query="SELECT * FROM data_central_wh.gold.vw_ibmi_settlement_revenue_history WHERE set_rev_hist_record_date BETWEEN DATEADD(week, -13, GETDATE()) AND GETDATE()"])
