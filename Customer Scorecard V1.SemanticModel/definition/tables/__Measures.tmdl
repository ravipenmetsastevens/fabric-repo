	measure 'Selected Filters Summary' = ```
			
			VAR MaxFilters = 2
			RETURN
			  IF ( 
			    ISFILTERED ( Divisions[Division Fleet Name] ), 
			    VAR ___f = FILTERS ( Divisions[Division Fleet Name] ) 
			    VAR ___d = CONCATENATEX ( ___f, Divisions[Division Fleet Name], ", " )
			    VAR ___x = "𝐅𝐥𝐞𝐞𝐭 - " & ___d 
			    RETURN ___x & UNICHAR(13) & UNICHAR(10))
			 & IF ( 
			    ISFILTERED ( Divisions[Division Code] ), 
			    VAR ___f = FILTERS ( Divisions[Division Code] ) 
			    VAR ___d = CONCATENATEX ( ___f, Divisions[Division Code], ", " )
			    VAR ___x = "𝐃𝐢𝐯𝐢𝐬𝐢𝐨𝐧 - " & ___d 
			    RETURN ___x & UNICHAR(13) & UNICHAR(10)
			)
			 & IF ( 
			    ISFILTERED ( 'Bill-To Customers'[Customer Name] ), 
			    VAR ___f = FILTERS ( 'Bill-To Customers'[Customer Name] ) 
			    VAR ___d = CONCATENATEX ( ___f, 'Bill-To Customers'[Customer Name], ", " )
			    VAR ___x = "𝐂𝐮𝐬𝐭𝐨𝐦𝐞𝐫 𝐍𝐚𝐦𝐞 - " & ___d 
			    RETURN ___x & UNICHAR(13) & UNICHAR(10)
			) 
			 & IF ( 
			    ISFILTERED ( 'Bill-To Customers'[Customer Code] ), 
			    VAR ___f = FILTERS ( 'Bill-To Customers'[Customer Code] ) 
			    VAR ___d = CONCATENATEX ( ___f, 'Bill-To Customers'[Customer Code], ", " )
			    VAR ___x = "𝐂𝐮𝐬𝐭𝐨𝐦𝐞𝐫 𝐂𝐨𝐝𝐞 - " & ___d 
			    RETURN ___x & UNICHAR(13) & UNICHAR(10)
			)
			 & IF ( 
			    ISFILTERED ( 'Load-At Customers'[Customer Name] ), 
			    VAR ___f = FILTERS ( 'Load-At Customers'[Customer Name] ) 
			    VAR ___d = CONCATENATEX ( ___f, 'Load-At Customers'[Customer Name], ", " )
			    VAR ___x = "𝐅𝐚𝐜𝐢𝐥𝐢𝐭𝐲 𝐍𝐚𝐦𝐞 - " & ___d 
			    RETURN ___x & UNICHAR(13) & UNICHAR(10)
			) 
			 & IF ( 
			    ISFILTERED ( Orders[Lane] ), 
			    VAR ___f = FILTERS ( Orders[Lane] ) 
			    VAR ___d = CONCATENATEX ( ___f, Orders[Lane], ", " )
			    VAR ___x = "𝐋𝐚𝐧𝐞 - " & ___d 
			    RETURN ___x & UNICHAR(13) & UNICHAR(10)
			)
			
			```
		lineageTag: d971eb17-cf93-48da-ab82-c58edffd14a1

