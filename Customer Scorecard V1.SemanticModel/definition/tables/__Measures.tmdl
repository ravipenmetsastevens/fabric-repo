table __Measures
	lineageTag: d2f3dfaa-aa43-4306-a5f1-365d5568a8f0

	measure 'Delivery Stop Count' = CALCULATE( COUNTA(Stops[Load Number]),FILTER(Stops,Stops[Stop Type] = "DELIVERY" && NOT(ISBLANK(Stops[Arrival Date])) ))
		formatString: #,0
		lineageTag: c133d620-7860-4d16-8590-aff3b55640d0

	measure 'Pickup Stop Count' = CALCULATE( COUNTA(Stops[Load Number]),FILTER(Stops,Stops[Stop Type] = "PICKUP" && NOT(ISBLANK(Stops[Actual Arrival DateTime]))))
		formatString: #,0
		lineageTag: c58b53e8-d12c-4de6-afde-bee121489eea

	measure 'On-Time Pickup % (Exception Adjusted)' =
			
			VAR Total = [Total Pickup Count Filtered]
			VAR Late  = CALCULATE(SUM(Stops[Late Pickup Count Original]), Stops[Has Late Service Exception] <> 2)
			RETURN
			    DIVIDE(Total - Late, Total, 0)
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: bba1708f-fe29-4eb2-9935-882e0ff731d3

	measure 'On-Time Delivery % (Exception Adjusted)' = ```
			
			VAR Total = [Total Delivery Count Filtered]
			VAR Late  = CALCULATE(SUM(Stops[Late Delivery Count Original]), Stops[Has Late Service Exception] <> 2)
			RETURN
			    DIVIDE(Total - Late, Total, 0)
			
			```
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: 7944a45c-fb52-4b01-843d-50478672a985

	measure 'On-Time Delivery %' = 1- DIVIDE(SUM(Stops[Late Delivery Count]),[Total Delivery Count Filtered])
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: 1b476832-1d76-471b-8077-f487ae047457

	measure 'On-Time Pickup %' = ```
