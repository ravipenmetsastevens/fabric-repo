	measure 'Customer Delivery Weight' = ```
			
			DIVIDE(
			    [Total Delivery Count Filtered],
			    CALCULATE(
			        [Delivery Stop Count],
			        ALLSELECTED('Bill-To Customers'[Customer Name])
			    ),
			    0
			)
			
			```
		lineageTag: 86b3b119-49bb-45de-a1a3-0bb495cfb605

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Customer Weighted On-Time Delivery Score' =
			
