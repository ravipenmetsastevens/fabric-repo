	measure 'Max Current Value' = ```
			
			VAR Vals =
			    CALCULATETABLE(
			        ADDCOLUMNS(
			            SUMMARIZE('Datetime', 'DateTime'[MonthNum], 'Datetime'[Month Letter]),
			            "@Measure", [Selected Measure]
			        ),
			        ALLSELECTED()
			    )
			
			VAR HighestValue = MaxX(Vals, [@Measure])
			VAR CurrentValue = [Selected Measure]
			VAR CurrentMonth = SELECTEDVALUE('DateTime'[MonthNum]) 
			
			RETURN
			    IF(CurrentValue = HighestValue, CurrentValue, BLANK())
