	measure 'Tender Acceptance %' =
			
			VAR Total = [Accepted Tender Count] + [Rejected Tender Count]
			VAR Reject  = [Rejected Tender Count]
			RETURN
			    DIVIDE(Total - Reject, Total, 0)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: a376d8b3-6676-4d49-ae7e-b98252717171

