	measure 'Customer Tender Acceptance Weight' =
			
			DIVIDE(
			    [Load Count],
			    CALCULATE(
			        [Load Count],
			        ALLSELECTED('Bill-To Customers'[Customer Name])
			    ),
			    0
			)
