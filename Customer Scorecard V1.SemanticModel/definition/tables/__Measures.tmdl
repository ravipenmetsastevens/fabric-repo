	measure 'OG OTP % Unscrubbed Day' =
			
			VAR Total = [Total Pickup Count Filtered]
			VAR Late  = SUM(Stops[Late Pickup Count Original Day])
			RETURN
			    DIVIDE(Total - Late, Total, 0)
		formatString: 0%;-0%;0%
		lineageTag: 27a8c8b1-435b-4ab8-afdf-40c91224908b

	measure 'OTP % Scrubbed Day' =
			
			VAR Total = [Total Pickup Count Filtered]
			VAR Late  = CALCULATE(SUM(Stops[Late Pickup Count Original Day]), Stops[Has Late Service Exception] <> 2)
			RETURN
			    DIVIDE(Total - Late, Total, 0)
		formatString: 0%;-0%;0%
		lineageTag: 4c3d0c3f-1923-4347-812d-276117f957aa

