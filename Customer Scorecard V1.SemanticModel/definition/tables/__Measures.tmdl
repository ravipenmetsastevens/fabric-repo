	measure 'Is Customer Name Filtered' = INT(ISFILTERED('Bill-To Customers'[Customer Name]))
		formatString: 0
		lineageTag: db54ec84-8e64-4694-8754-b62cf807a74c

	measure 'Selected Bill-To Customer Filters' = ```
			
			VAR MaxFilters = 3
			RETURN
			IF ( 
			    ISFILTERED ( 'Bill-To Customers'[City Code] ), 
			    VAR ___f = FILTERS ( 'Bill-To Customers'[City Code] ) 
			    VAR ___r = COUNTROWS ( ___f ) 
			    VAR ___t = TOPN ( MaxFilters, ___f, 'Bill-To Customers'[City Code] )
			    VAR ___d = CONCATENATEX ( ___t, 'Bill-To Customers'[City Code], ", " )
			    VAR ___x = "dim_Customer_Billto[Customer City Code] = " & ___d & IF(___r > MaxFilters, ", ... [" & ___r & " items selected]") & " " 
			    RETURN ___x & UNICHAR(13) & UNICHAR(10)
			)
			
			 & IF ( 
			    ISFILTERED ( 'Bill-To Customers'[Customer Name] ), 
			    VAR ___f = FILTERS ( 'Bill-To Customers'[Customer Name] ) 
			    VAR ___d = CONCATENATEX ( ___f, 'Bill-To Customers'[Customer Name], ", " )
			    VAR ___x = "𝐂𝐮𝐬𝐭𝐨𝐦𝐞𝐫 𝐍𝐚𝐦𝐞 (" & ___d & ") " 
			    RETURN ___x & UNICHAR(13) & UNICHAR(10)
			) 
			 & IF ( 
			    ISFILTERED ( 'Bill-To Customers'[Customer Code] ), 
			    VAR ___f = FILTERS ( 'Bill-To Customers'[Customer Code] ) 
			    VAR ___d = CONCATENATEX ( ___f, 'Bill-To Customers'[Customer Code], ", " )
			    VAR ___x = "𝐂𝐮𝐬𝐭𝐨𝐦𝐞𝐫 𝐂𝐨𝐝𝐞 (" & ___d & ") " 
			    RETURN ___x & UNICHAR(13) & UNICHAR(10)
			)
			 & IF ( 
			    ISFILTERED ( 'Bill-To Customers'[State] ), 
			    VAR ___f = FILTERS ( 'Bill-To Customers'[State] ) 
			    VAR ___r = COUNTROWS ( ___f ) 
			    VAR ___t = TOPN ( MaxFilters, ___f, 'Bill-To Customers'[State] )
			    VAR ___d = CONCATENATEX ( ___t, 'Bill-To Customers'[State], ", " )
			    VAR ___x = "dim_Customer_Billto[Customer State] = " & ___d & IF(___r > MaxFilters, ", ... [" & ___r & " items selected]") & " " 
			    RETURN ___x & UNICHAR(13) & UNICHAR(10)
			)
			```
		lineageTag: 51f27735-d7d5-4cf2-a89e-8cbb80c85707

